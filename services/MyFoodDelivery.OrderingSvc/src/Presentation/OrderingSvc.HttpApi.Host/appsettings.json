{
  "App": {
    "CorsOrigins": [
      "http://localhost:4200",
      "http://localhost:5000"
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=.;Database=MyFoodDelivery_Ordering;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Redis": {
    "Configuration": "localhost:6379"
  },
  "Stripe": {
    "SecretKey": "sk_test_your_stripe_secret_key",
    "WebhookSecret": "whsec_your_webhook_secret"
  },
  "RabbitMQ": {
    "Connections": {
      "Default": {
        "HostName": "localhost",
        "Port": 5672,
        "UserName": "guest",
        "Password": "guest"
      }
    },
    "EventBus": {
      "ClientName": "OrderingSvc",
      "ExchangeName": "MyFoodDelivery"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
