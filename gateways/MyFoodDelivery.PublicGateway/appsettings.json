{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  
  "Authentication": {
    "Authority": "http://localhost:5050",
    "Audience": "myfooddelivery-api"
  },
  
  "Redis": {
    "Configuration": "localhost:6379"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-token-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      },
      "auth-account-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        }
      },
      "customer-route": {
        "ClusterId": "customer-cluster",
        "Match": {
          "Path": "/api/customers/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "customer-addresses-route": {
        "ClusterId": "customer-cluster",
        "Match": {
          "Path": "/api/customers/me/addresses/{**catch-all}"
        }
      },
      "customer-loyalty-route": {
        "ClusterId": "customer-cluster",
        "Match": {
          "Path": "/api/customers/me/loyalty/{**catch-all}"
        }
      },
      "customer-payment-route": {
        "ClusterId": "customer-cluster",
        "Match": {
          "Path": "/api/customers/me/payment-methods/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "cart-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/cart/{**catch-all}"
        }
      },
      "restaurant-route": {
        "ClusterId": "restaurant-cluster",
        "Match": {
          "Path": "/api/restaurants/{**catch-all}"
        }
      },
      "menu-route": {
        "ClusterId": "restaurant-cluster",
        "Match": {
          "Path": "/api/menus/{**catch-all}"
        }
      },
      "delivery-route": {
        "ClusterId": "delivery-cluster",
        "Match": {
          "Path": "/api/delivery/{**catch-all}"
        }
      },
      "rider-route": {
        "ClusterId": "delivery-cluster",
        "Match": {
          "Path": "/api/riders/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "auth-svc": {
            "Address": "http://localhost:5050/"
          }
        }
      },
      "customer-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "customer-svc": {
            "Address": "http://localhost:5010/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "ordering-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "ordering-svc": {
            "Address": "http://localhost:5020/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "restaurant-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "restaurant-svc": {
            "Address": "http://localhost:5030/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "delivery-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "delivery-svc": {
            "Address": "http://localhost:5040/"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}
